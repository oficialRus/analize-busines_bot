# Публичный URL приложения (для ссылок, метаданных, будущих интеграций)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 2GIS Places API — только сервер (route handlers). На клиент не передавать.
# https://platform.2gis.ru/
DGIS_API_KEY=

# Локаль поиска в каталоге 2GIS (по умолчанию ru_RU — лучше для РФ)
# DGIS_LOCALE=ru_RU

# Демо-ключ 2GIS: page_size не больше 10 (в коде по умолчанию max=10). Для полного ключа часто можно 50:
# DGIS_MAX_PAGE_SIZE=50

# Сколько ячеек сетки за один анализ (по умолчанию 36, макс. 400). Для всего Краснодара часто нужно 100–200 + крупный шаг сетки.
# GRID_MAX_CELLS=120
# То же число для подсказок в форме (иначе клиент считает лимит 36):
# NEXT_PUBLIC_GRID_MAX_CELLS=120

# Опционально: путь к файлу SQLite с историей сеточных анализов (по умолчанию data/analysis-history.db)
# ANALYSIS_DB_PATH=

# Зарезервировано под backend API (следующий этап)
# NEXT_PUBLIC_API_URL=
# API_SECRET_KEY=
